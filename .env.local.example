# Required — server-side only, never exposed to the browser.
ANTHROPIC_API_KEY=

# Optional for v1. Raises the GitHub REST rate limit from 60 to 5,000 req/hr.
# Required once you add the private-repo OAuth phase.
GITHUB_TOKEN=

# Optional — override the Claude model used by all three agents.
# ANTHROPIC_MODEL=claude-sonnet-4-6
